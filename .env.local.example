# Supabase Vena Coffee Machine
NEXT_PUBLIC_SUPABASE_URL=https://sykxuautgcczsxhfossj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=la-tua-anon-key
SUPABASE_SERVICE_ROLE_KEY=la-tua-service-role-key

# Resend (email transazionale)
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM="Vena Coffee Machine <onboarding@resend.dev>"

# URL pubblico dell'app (per i link di tracking, prenotazione e CTA)
NEXT_PUBLIC_APP_URL=https://venamachine-production.up.railway.app

# Admin interno: serve solo per creare operatori da /admin/operatori.
# Non crea registrazioni pubbliche e non va condiviso agli operatori.
ADMIN_PIN=cambia-questo-pin

# Payment notifications
# Admin singolo o lista admin separate da virgola.
ADMIN_EMAIL=admin@venacoffee.it
ADMIN_EMAILS=admin@venacoffee.it

# WhatsApp / OpenWA (servizio Railway separato o provider compatibile)
OPENWA_URL=
OPENWA_API_KEY=
OPENWA_SESSION=
ADMIN_PHONE=
WHATSAPP_WORKER_BATCH_SIZE=10
WHATSAPP_WORKER_POLL_MS=5000
WORKER_ID=venamachine-whatsapp
